#!/usr/bin/python3
#
# /// script
# dependencies = [
#   "click",
#   "requests",
#   "ruamel.yaml",
# ]
# ///

"""
List issues and pull requests with story points for the given sprint
"""

import os
import re
import sys
import traceback
from collections import defaultdict
from typing import Any, Optional

import click
import requests
from ruamel.yaml import YAML
from typing_extensions import TypeAlias  # noqa: TID251

GITHUB_API_URL = "https://api.github.com"
GITHUB_API_VERSION = "2026-03-10"
GITHUB_ORGANIZATION = "teemtee"
GITHUB_PROJECT_NUMBER = 1
GITHUB_ITEMS_PER_PAGE = 100


Item: TypeAlias = dict[str, Any]


def header(text: str, char: str = "-", top: bool = False) -> None:
    """
    Print a header with the given text and a separator line below it.

    :param text: header text, can be multiline.
    :param char: character to use for the separator lines.
    :param top: if set, print a separator line above the text as well.
    """

    separator = char * 80
    print()
    if top:
        print(separator)
    print(text)
    print(separator)


def github_api_get(
    path: str,
    params: Optional[dict[str, str]] = None,
    url: Optional[str] = None,
) -> requests.Response:
    """
    Make a GET request to the GitHub REST API.

    :param path: API path relative to the project endpoint,
        e.g. ``fields`` or ``items``. Ignored when ``url`` is given.
    :param params: optional query parameters.
    :param url: if set, use this full URL instead of building one from ``path``.
    :returns: the HTTP response.
    """

    if url is None:
        url = (
            f"{GITHUB_API_URL}/orgs/{GITHUB_ORGANIZATION}"
            f"/projectsV2/{GITHUB_PROJECT_NUMBER}/{path}"
        )
    headers: dict[str, str] = {
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": GITHUB_API_VERSION,
    }
    token = os.environ.get("GITHUB_PERSONAL_ACCESS_TOKEN")
    if token:
        headers["Authorization"] = f"Bearer {token}"

    response = requests.get(url, headers=headers, params=params, timeout=30)
    response.raise_for_status()
    return response


def fetch_field_ids() -> tuple[int, int]:
    """
    Fetch the field IDs for Size and Sprint from the project.

    :returns: a tuple ``(size_field_id, sprint_field_id)``.
    """

    response = github_api_get("fields")

    size_id = sprint_id = None
    for field in response.json():
        if field["name"] == "Size":
            size_id = field["id"]
        elif field["name"] == "Sprint":
            sprint_id = field["id"]

    if size_id is None or sprint_id is None:
        print("Error: Could not find Size and Sprint fields in the project", file=sys.stderr)
        sys.exit(1)

    return size_id, sprint_id


def fetch_sprint_items(sprint_name: str) -> list[Item]:
    """
    Fetch all items in the given sprint.

    :param sprint_name: name of the sprint to fetch items for.
    :returns: a list of dictionaries with keys ``id``, ``type``, ``status``,
        ``size``, ``url``, and ``title``.
    """

    print(
        f"Fetching items from {GITHUB_ORGANIZATION}/project/{GITHUB_PROJECT_NUMBER}"
        f" for sprint '{sprint_name}'...",
        file=sys.stderr,
    )

    size_field_id, sprint_field_id = fetch_field_ids()

    response = github_api_get(
        "items",
        params={
            "per_page": str(GITHUB_ITEMS_PER_PAGE),
            "fields": f"{size_field_id},{sprint_field_id}",
            "q": f'Sprint:"{sprint_name}"',
        },
    )

    all_items: list[Item] = []
    page = 1

    while True:
        items = response.json()
        print(f"Page {page}: {len(items)} items", file=sys.stderr)

        for item in items:
            content = item.get("content")
            if not content:
                continue

            item_type = "pull" if item["content_type"] == "PullRequest" else "issue"
            size_field = next((f for f in item.get("fields", []) if f["name"] == "Size"), None)
            size = size_field.get("value") if size_field else None

            if item_type == "pull":
                status = "merged" if content.get("merged_at") else content["state"]
            else:
                status = content["state"]

            all_items.append(
                {
                    "id": content["number"],
                    "type": item_type,
                    "status": status,
                    "size": size,
                    "url": content["html_url"],
                    "title": content["title"],
                }
            )

        # Follow pagination via Link header
        link_header = response.headers.get("Link", "")
        match = re.search(r'<([^>]+)>;\s*rel="next"', link_header)
        if not match:
            break

        response = github_api_get("", url=match.group(1))
        page += 1

    print(f"Total: {len(all_items)} items", file=sys.stderr)
    return all_items


def categorize_items(items: list[Item]) -> dict[str, list[Item]]:
    """
    Categorize items by type and status.

    :param items: list of item dictionaries as returned by
        :py:func:`fetch_sprint_items`.
    :returns: dictionary with category keys like ``open-issue``,
        ``merged-pull``, ``closed-issue``, etc.
    """
    categories: dict[str, list[Item]] = defaultdict(list)

    for item in items:
        categories[f'{item["status"]}-{item["type"]}'].append(item)

    # Sort all categories by id
    for items_list in categories.values():
        items_list.sort(key=lambda item: item["id"])

    return categories


def display_category(label: str, items: list[Item]) -> None:
    header(f"{label} ({len(items)}) - {sum(item['size'] or 0 for item in items)} points:")
    for item in items:
        size_str = f"[{item['size']}]" if item["size"] is not None else "[-]"
        print(f"  #{item['id']:<4} {size_str:>4} {item['title']}")


def display_items(sprint_name: str, categories: dict[str, list[Item]]) -> None:
    """
    Display categorized items in a readable format with story points.

    :param sprint_name: name of the sprint being displayed.
    :param categories: dictionary of categorized items returned by
        :py:func:`categorize_items`.
    """
    total = sum(len(items) for items in categories.values())

    # Calculate total story points by category
    total_points: dict[str, int] = {}
    for key, items in categories.items():
        total_points[key] = sum(item["size"] or 0 for item in items)

    header(
        f"Sprint: {sprint_name}\n"
        f"Total items: {total}\n"
        f"Total story points: {sum(total_points.values())}",
        char="=",
        top=True,
    )

    # Define display order and labels
    sections = [
        ("open-issue", "Open Issues"),
        ("open-pull", "Open Pull Requests"),
        ("closed-issue", "Closed Issues"),
        ("merged-pull", "Merged Pull Requests"),
        ("closed-pull", "Closed Pull Requests"),
    ]

    for key, label in sections:
        if categories.get(key):
            display_category(label, categories[key])

    # Summary
    open_count = len(categories.get("open-issue", [])) + len(categories.get("open-pull", []))
    closed_count = total - open_count
    open_points = total_points.get("open-issue", 0) + total_points.get("open-pull", 0)
    closed_points = sum(total_points.values()) - open_points

    header(
        f"Summary: {open_count} open ({open_points} pts), "
        f"{closed_count} closed/merged ({closed_points} pts)",
        char="=",
        top=True,
    )


def display_comparison(base: list[Item], current: list[Item]) -> None:
    base.sort(key=lambda x: x['id'])

    base_map = {item['id']: item for item in base}
    current_map = {item['id']: item for item in current}

    completed: list[Item] = []
    pending: list[Item] = []
    added: list[Item] = []
    removed: list[Item] = []

    for base_id, base_item in base_map.items():
        current_item = current_map.pop(base_id, None)

        if current_item is None:
            removed.append(base_item)

        elif current_item['status'] in ('closed', 'merged'):
            completed.append(base_item)

        else:
            pending.append(base_item)

    for current_item in current_map.values():
        added.append(current_item)

        if current_item['status'] in ('closed', 'merged'):
            completed.append(current_item)

        else:
            pending.append(current_item)

    def size(items: list[Item]) -> int:
        return sum(item['size'] or 0 for item in items)

    count_base, count_current, size_base, size_current = (
        len(base),
        len(current),
        size(base),
        size(current),
    )
    count_completed, count_pending, size_completed, size_pending = (
        len(completed),
        len(pending),
        size(completed),
        size(pending),
    )
    count_added, size_added = len(added), size(added)

    header(
        f"Total items: {count_base} => {count_current}\n"
        f"Total story points: {size_base} => {size_current}\n"
        f"Completed items: {count_completed} vs {count_pending} items,"
        f" {size_completed} vs {size_pending} points\n"
        f"Added items: {count_added} ({count_added / count_base * 100:.0f} %),"
        f" {size_added} ({size_added / size_base * 100:.0f} %)",
        char="=",
        top=True,
    )

    display_category('Completed', completed)
    display_category('Pending', pending)
    display_category('Added', added)
    display_category('Removed', removed)

    display_category('Added and incomplete', [item for item in added if item not in completed])


@click.command()
@click.argument(
    'sprint_name',
    metavar='SPRINT_NAME',
    default='@current',
)
@click.option(
    '--yaml',
    'output_yaml',
    is_flag=True,
    help='Output in YAML format for machine-readable processing.',
)
@click.option(
    '--base',
    'base_path',
    default=None,
    help='Instead of reporting, compare the current sprint against this saved state.',
)
@click.option(
    '--current',
    'current_path',
    default=None,
    help='If set, compare --base against --current instead of the live sprint state.',
)
def main(
    sprint_name: str,
    output_yaml: bool,
    base_path: Optional[str] = None,
    current_path: Optional[str] = None,
) -> None:
    """
    List all issues and pull requests in a GitHub Project sprint with story points.

    SPRINT_NAME: Name of the sprint (e.g., 'Sprint 11')

    Set the GITHUB_PERSONAL_ACCESS_TOKEN environment variable to avoid rate limits.

    # Comparison

    Use --base to compare sprint state in different points in time. For example,
    save the sprint overview using --yaml at the beginning of the sprint, then
    at some time later, pass the saved file to --base to get overview of what
    happened to various items.
    """
    try:
        if current_path is not None:
            with open(current_path) as f:
                items = YAML().load(f)

        else:
            items = fetch_sprint_items(sprint_name)

            if not items:
                print(f"No items found in sprint '{sprint_name}'.")
                return

        if output_yaml:
            YAML().dump(items, sys.stdout)

        elif base_path is not None:
            with open(base_path) as f:
                base = YAML().load(f)

            display_comparison(base, items)

        else:
            categories = categorize_items(items)
            display_items(sprint_name, categories)

    except requests.exceptions.RequestException as error:
        print(f"Error making API request: {error}", file=sys.stderr)
        traceback.print_exc()
        sys.exit(1)

    except Exception as error:
        print(f"Error: {error}", file=sys.stderr)
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
