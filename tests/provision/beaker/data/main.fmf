/plan:
    execute:
        how: tmt

    provision:
        how: beaker

/plan/hardware:
    provision+:
        hardware:
            cpu:
                model-name: dummy
                processors: 6

/plan/bootc:
    provision+:
        bootc: True
        image_url: quay.io/fedora/custom-bootc:latest
        bootc_secret: dummysecret
        distro_name: 41
