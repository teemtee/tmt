discover:
    - how: fmf
      filter: tag:-extra
provision:
    how: virtual
    image: $@{distro}
execute:
    how: upgrade
    url: https://github.com/teemtee/upgrade

/no-path:
    summary: Basic upgrade test with no upgrade path
/path:
    summary: Basic upgrade test with upgrade path
    execute+:
        upgrade-path: $@{upgrade-path}
/add-phase:
    summary: Upgrade test with upgrade path and extra discover phase
    execute+:
        upgrade-path: $@{upgrade-path}
    discover+:
        - name: extra-phase
          how: fmf
          filter: tag:extra
/skip-tests:
    /before:
        execute+:
            upgrade-path: $@{upgrade-path}
            skip-tests-before: true

    /after:
        execute+:
            upgrade-path: $@{upgrade-path}
            skip-tests-after: true
