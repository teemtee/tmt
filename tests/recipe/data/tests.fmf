test: /bin/true

/first:
    summary: First test
    framework: beakerlib
    test: ./test.sh
    environment:
        TEST_ENV: test_value
    require:
      - url: https://github.com/beakerlib/test
        name: /very/deep/file
        type: library
/second:
    summary: Second test
    framework: shell
    test: echo SECOND_TEST
    check:
      - how: dmesg
        result: info
