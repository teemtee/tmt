provision:
    how: container
    environment:
        PROVISION_ENV: provision_value
environment:
    PLAN_ENV: plan_value

/simple:
    summary: A simple plan
    link: https://something.org/related
    discover:
      - name: discover-fmf
        how: fmf
      - name: discover-shell
        how: shell
        tests:
          - name: /shell-test
            test: /bin/true
    prepare:
        how: shell
        script: echo "Prepare phase"
    execute:
      - name: Execute phase
        how: tmt
    finish:
        how: shell
        script: echo "Finish phase"

/insert:
    summary: A plan with inserted steps
    discover:
      - name: discover-shell
        how: shell
        tests:
          - name: /shell-test
            test: /bin/true
    execute:
        how: tmt

/remote:
    summary: A remote plan
    discover:
        how: fmf
        url: https://github.com/teemtee/tests
        test: /tests/one
    execute:
        how: tmt

/import:
    plan:
        import:
            url: https://github.com/teemtee/tests
            name: /plans/remote
