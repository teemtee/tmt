/plan/success:
    discover:
        how: fmf
        test: /test/success
    provision:
        how: container
    prepare:
      - how: artifact
        provide:
          - koji.build:DUMMY_KOJI_BUILD_ID
      - how: verify-installation
        order: 76
        verify:
          - package: make
            expected_repo: tmt-artifact-shared
          - package: make-devel
            expected_repo: tmt-artifact-shared
          - package: diffutils
            expected_repo: fedora
    execute:
        how: tmt

/test/success:
    test: ./test-success.sh
    duration: 5m
    summary: Verify successful package source verification
    require:
      - make
      - make-devel
      - diffutils

/plan/failure:
    discover:
        how: fmf
        test: /test/failure
    provision:
        how: container
    prepare:
      - how: artifact
        provide:
          - koji.build:DUMMY_KOJI_BUILD_ID
      - how: verify-installation
        order: 76
        verify:
          - package: make
            expected_repo: tmt-artifact-shared
          - package: make-devel
            expected_repo: SOME_NON_EXISTENT_REPO
          - package: diffutils
            expected_repo: fedora
    execute:
        how: tmt

/test/failure:
    test: ./test-failure.sh
    duration: 5m
    summary: Verify package source verification fails with wrong repo
    require:
      - make
      - make-devel
      - diffutils
