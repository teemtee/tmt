summary: Test PrepareArtifact with multiple providers
description: |
    Test all artifact providers working together in a single prepare step.
    Validates that koji, file, and repository-url providers can coexist.
test: ./test.sh
duration: 15m
tag+:
  - provision-only
  - provision-container
adjust:
  - when: distro != fedora
    enabled: false
    because: Need to dynamically handle centos/brew/epel artifacts somehow also
