summary: Test PrepareArtifact file provider
description: |
    Test the file provider for PrepareArtifact plugin.
    Uses local RPM files as artifacts.
test: ./test.sh
duration: 10m
tag+:
  - provision-only
  - provision-container
adjust:
  - when: distro != fedora
    enabled: false
    because: Need to dynamically handle centos/brew/epel artifacts somehow also
