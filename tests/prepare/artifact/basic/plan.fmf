discover:
    how: fmf
prepare:
  - name: Sanity checks before artifact repo setup
    how: shell
    order: 20
    script: ./pre_artifact_check.sh
  - name: Main artifact to test
    how: artifact
    provide:
      - file:../rpms/bar/bar-1.0-1.noarch.rpm
  - name: Sanity checks after artifact repo setup
    how: shell
    order: 60
    script: ./post_artifact_check.sh
execute:
    how: tmt
