summary: Replacement package is available
description: |

  Pre-installed and system package should be ignored in this case

/basic:
  /upgrade:
    summary+: " (replacement on artifact)"
    description+<: |
      System repo: foo-1.4 (baseline)
      Pre-installed: None
      Artifacts: foo-ng-1.0

    context+:
      verified_artifact: foo-ng-1.0
    environment+:
      EXPECTED_PACKAGE: foo-ng-1.0

  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.0
      Pre-installed: None
      Artifacts: foo-1.1

    context+:
      verified_artifact: foo-1.1
    environment+:
      SYSTEM_PACKAGE: foo-ng-1.0
      EXPECTED_PACKAGE: foo-1.1

/pre-installed:
  summary+: " (foo pre-installed)"
  /upgrade:
    summary+: " (replacement on artifact)"
    description: |
      System repo: foo-1.4 (baseline)
      Pre-installed: foo-1.4
      Artifacts: foo-ng-1.0

    context+:
      verified_artifact: foo-ng-1.0
    environment+:
      PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm
      EXPECTED_PACKAGE: foo-ng-1.0

    /only-foo:
      summary+: " (only foo requested)"

    /with-devel:
      summary+: " (requested devel)"
      context+:
        want_devel: "true"
      environment+:
        EXPECTED_PACKAGE+: " foo-ng-devel-1.0"

  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.0
      Pre-installed: foo-ng-1.0
      Artifacts: foo-1.1

    context+:
      verified_artifact: foo-1.1
    environment+:
      SYSTEM_PACKAGE: foo-ng-1.0
      PRE_INSTALLED_PACKAGE: rpms/foo-ng-1.0/foo-ng-1.0*.rpm
      EXPECTED_PACKAGE: foo-1.1

    /only-foo:
      summary+: " (only foo requested)"
      context+:
        # TODO(#4838)
        # Because presence check gets in the way.
        # It should fail at verify phase and test execution.
        xfail: "true"

    /with-devel:
      summary+: " (requested devel)"
      context+:
        want_devel: "true"
      environment+:
        EXPECTED_PACKAGE+: " foo-devel-1.1"
