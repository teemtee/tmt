summary: Replacement package is available

environment+:
  SYSTEM_PACKAGE+: " foo-ng-1.0"
  EXPECTED_PACKAGE: foo-ng-1.0

/basic:
  summary+: " (only foo requested)"
  description: |
    System repo: foo-1.4 (baseline), foo-ng-1.0
    Pre-installed: None
    Artifacts: None

    `foo-ng` should be picked over the obsoleted one regardless
    of the `Provides` version provided.

/pre-installed:
  summary+: " (foo pre-installed)"
  description: |
    System repo: foo-1.4 (baseline), foo-ng-1.0
    Pre-installed: foo-1.4
    Artifacts: None

  environment+:
    PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm
    EXPECTED_PACKAGE: foo-1.4

  /only-foo:
    summary+: " (only foo requested)"
    description+: |

      `foo-ng` is not upgraded because of `check-first` flag.
      dnf would also only upgrade if `--best` flag is provided

    environment+:
      EXPECTED_PACKAGE: foo-1.4

  /with-devel:
    summary+: " (requested devel)"
    description+: |

      `foo-ng-devel` is preferred with the Obsoletes rule and
      replaces `foo`
    context+:
      want_devel: "true"
    environment+:
      EXPECTED_PACKAGE+: " foo-devel-1.4"
