summary: Pre-installed package present (non-verified)
description: |
  System repo: foo-1.4 (baseline)
  Pre-installed: foo-1.4
  Artifacts: foo-2.2 or foo-1.2

  Pre-installed package should be respected in this case

environment+:
  PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm

/upgrade:
  summary: " (upgrading)"
  context+:
    available_artifact: foo-2.2
  environment+:
    EXPECTED_PACKAGE: foo-1.4
  /only-foo:
    summary+: " (only foo requested)"

  /with-devel:
    summary+: " (requested devel)"
    description+: |
      Because we request `foo-devel`, it will upgrade foo to 2.2.
    context+:
      want_devel: "true"
    environment+:
      EXPECTED_PACKAGE: foo-2.2 foo-devel-2.2

/downgrade:
  summary: " (downgrading)"
  context+:
    available_artifact: foo-1.2
  environment+:
    EXPECTED_PACKAGE: foo-1.4
  /only-foo:
    summary+: " (only foo requested)"

  /with-devel:
    summary+: " (requested devel)"
    description+: |
      Because we request `foo-devel`, it will downgrade foo to 1.2.
    context+:
      want_devel: "true"
    environment+:
      EXPECTED_PACKAGE: foo-1.2 foo-devel-1.2
