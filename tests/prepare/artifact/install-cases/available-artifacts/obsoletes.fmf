summary: Replacement package is available

/basic:
  description+<: |

    Artifact's priority wins over `Obsoletes`
  /upgrade:
    summary+: " (replacement on artifact)"
    description: |
      System repo: foo-1.4 (baseline)
      Pre-installed: None
      Artifacts: foo-ng-1.0

    context+:
      available_artifact: foo-ng-1.0
    environment+:
      EXPECTED_PACKAGE: foo-ng-1.0
  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.0
      Pre-installed: None
      Artifacts: foo-1.2

    context+:
      available_artifact: foo-1.2
    environment+:
      EXPECTED_PACKAGE: foo-1.2
      SYSTEM_PACKAGE: foo-ng-1.0

/pre-installed:
  summary+: " (foo pre-installed)"
  /upgrade:
    summary+: " (replacement on artifact)"
    description: |
      System repo: foo-1.4 (baseline)
      Pre-installed: foo-1.4
      Artifacts: foo-ng-1.0

    context+:
      available_artifact: foo-ng-1.0
    environment+:
      PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm

    /only-foo:
      summary+: " (only foo requested)"
      description+: |

        `foo-ng` is not upgraded because of `check-first` flag.
        dnf would also only upgrade if `--best` flag is provided

      environment+:
        EXPECTED_PACKAGE+: foo-1.4

    /with-devel:
      summary+: " (requested devel)"
      description+: |

        `foo` will upgrade to `foo-ng` when trying to install a `foo-devel`.
        Artifact's priority wins over the Obsoletes.

      context+:
        want_devel: "true"
      environment+:
        EXPECTED_PACKAGE: foo-ng-1.0 foo-ng-devel-1.0

  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.0
      Pre-installed: foo-ng-1.0
      Artifacts: foo-1.2

    context+:
      available_artifact: foo-1.2
    environment+:
      SYSTEM_PACKAGE: foo-ng-1.0
      PRE_INSTALLED_PACKAGE: rpms/foo-ng-1.0/foo-ng-1.0*.rpm

    /only-foo:
      summary+: " (only foo requested)"
      description+: |

        Nothing is changed because of `check-first` flag.

      environment+:
        EXPECTED_PACKAGE+: foo-ng-1.0

    /with-devel:
      summary+: " (requested devel)"
      description+: |

        `foo` is preferred, but it cannot be installed due to the Obsoletes.
        Package installation fallback to `foo-ng`
      context+:
        want_devel: "true"
      environment+:
        EXPECTED_PACKAGE+: foo-ng-1.0 foo-ng-devel-1.0
