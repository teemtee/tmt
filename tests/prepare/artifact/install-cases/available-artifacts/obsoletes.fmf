summary: Replacement package is available

environment+:
  EXPECTED_PACKAGE: foo-ng-1.4

/basic:
  /upgrade:
    summary+: " (replacement on artifact)"
    description: |
      System repo: foo-1.4 (baseline)
      Pre-installed: None
      Artifacts: foo-ng-1.4

      `foo-ng` should remove the old package via the `Obsoletes`

    context+:
      available_artifact: foo-ng-1.4
  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.4
      Pre-installed: None
      Artifacts: foo-1.2

      `foo-ng` should remove the old package via the `Obsoletes`

    context+:
      available_artifact: foo-1.2
    environment+:
      SYSTEM_PACKAGE: foo-ng-1.4

/pre-installed:
  summary+: " (foo pre-installed)"
  /upgrade:
    summary+: " (replacement on artifact)"
    description: |
      System repo: foo-1.4 (baseline)
      Pre-installed: foo-1.4
      Artifacts: foo-ng-1.4

      `foo-ng` should remove the old package via the `Obsoletes`

    context+:
      available_artifact: foo-ng-1.4
    environment+:
      PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm

    /only-foo:
      summary+: " (only foo requested)"

    /with-devel:
      summary+: " (requested devel)"
      context+:
        want_devel: "true"
      environment+:
        EXPECTED_PACKAGE+: " foo-ng-devel-1.4"

  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.4
      Pre-installed: foo-ng-1.4
      Artifacts: foo-1.2

      `foo-ng` already installed, nothing should change

    context+:
      available_artifact: foo-1.2
    environment+:
      SYSTEM_PACKAGE: foo-ng-1.4
      PRE_INSTALLED_PACKAGE: rpms/foo-ng-1.4/foo-ng-1.4*.rpm

    /only-foo:
      summary+: " (only foo requested)"

    /with-devel:
      summary+: " (requested devel)"
      context+:
        want_devel: "true"
      environment+:
        EXPECTED_PACKAGE+: " foo-ng-devel-1.4"
