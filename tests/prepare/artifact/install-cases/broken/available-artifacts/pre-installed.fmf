summary: Pre-installed package present (non-verified, broken)
description: |
  System repo: foo-1.4 (baseline)
  Pre-installed: foo-1.4
  Artifacts: foo-2.2-bad or foo-1.2-bad

  Pre-installed package takes precedence, broken state does not matter

environment+:
  PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm
  EXPECTED_PACKAGE: foo-1.4

/upgrade:
  summary: " (upgrading)"
  context+:
    available_artifact: foo-2.2-bad

  /only-foo:
    summary+: " (only foo requested)"

  /with-devel:
    summary+: " (requested devel)"
    description+: |
      foo-devel will be installed from the system repo instead of artifact.
    context+:
      want_devel: "true"
    environment+:
      EXPECTED_PACKAGE+: " foo-devel-1.4"

/downgrade:
  summary: " (downgrading)"
  context+:
    available_artifact: foo-1.2-bad

  /only-foo:
    summary+: " (only foo requested)"

  /with-devel:
    summary+: " (requested devel)"
    description+: |
      foo-devel will be installed from the system repo instead of artifact.
    context+:
      want_devel: "true"
    environment+:
      EXPECTED_PACKAGE+: " foo-devel-1.4"
