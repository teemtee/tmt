summary: Pre-installed package present (non-verified, broken)
description: |
  System repo: foo-1.4 (baseline)
  Pre-installed: foo-1.4
  Artifacts: foo-2.2-bad or foo-1.2-bad

  Pre-installed package takes precedence, broken state does not matter

environment+:
  PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm

/upgrade:
  summary: " (upgrading)"
  context+:
    verified_artifact: foo-2.2-bad
  environment+:
    EXPECTED_PACKAGE: foo-1.4

/downgrade:
  summary: " (downgrading)"
  context+:
    verified_artifact: foo-1.2-bad
  environment+:
    EXPECTED_PACKAGE: foo-1.4
