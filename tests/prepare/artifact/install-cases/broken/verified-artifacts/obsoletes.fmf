summary: Replacement package is available (broken)
description: |

  Installation/verification must fail instead of going through a fallback

context+:
  # Tests are expected to fail at installation or verify step
  xfail: "true"

/basic:
  /upgrade:
    summary+: " (replacement on artifact)"
    description+<: |
      System repo: foo-1.4 (baseline)
      Pre-installed: None
      Artifacts: foo-ng-1.4-bad

    context+:
      verified_artifact: foo-ng-1.4-bad

  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.4
      Pre-installed: None
      Artifacts: foo-1.1-bad

    context+:
      verified_artifact: foo-1.1-bad
    environment+:
      SYSTEM_PACKAGE: foo-ng-1.4

/pre-installed:
  summary+: " (foo pre-installed)"
  /upgrade:
    summary+: " (replacement on artifact)"
    description: |
      System repo: foo-1.4 (baseline)
      Pre-installed: foo-1.4
      Artifacts: foo-ng-1.4-bad

    context+:
      verified_artifact: foo-ng-1.4-bad
    environment+:
      PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm

    /only-foo:
      summary+: " (only foo requested)"

    /with-devel:
      summary+: " (requested devel)"
      context+:
        want_devel: "true"

  /downgrade:
    summary+: " (replacement on system)"
    description: |
      System repo: foo-ng-1.4
      Pre-installed: foo-ng-1.4
      Artifacts: foo-1.1-bad

    context+:
      verified_artifact: foo-1.1-bad
    environment+:
      SYSTEM_PACKAGE: foo-ng-1.4
      PRE_INSTALLED_PACKAGE: rpms/foo-ng-1.4/foo-ng-1.4*.rpm

    /only-foo:
      summary+: " (only foo requested)"

    /with-devel:
      summary+: " (requested devel)"
      context+:
        want_devel: "true"
