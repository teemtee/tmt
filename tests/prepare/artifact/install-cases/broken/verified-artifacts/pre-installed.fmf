summary: Pre-installed package present (broken)
description: |
  System repo: foo-1.4 (baseline)
  Pre-installed: foo-1.4
  Artifacts: foo-2.4-bad or foo-1.1-bad

  Pre-installed package should be ignored and still give a failure

environment+:
  PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm
context+:
  # Tests are expected to fail at installation or verify step
  xfail: "true"

/upgrade:
  summary: " (upgrading)"
  context+:
    verified_artifact: foo-2.4-bad
  environment+:
    EXPECTED_PACKAGE: foo-2.4-bad

/downgrade:
  summary: " (downgrading)"
  context+:
    verified_artifact: foo-1.1-bad
  environment+:
    EXPECTED_PACKAGE: foo-1.1-bad
