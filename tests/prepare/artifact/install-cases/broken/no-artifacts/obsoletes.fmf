summary: Replacement package is available (broken)

environment+:
  SYSTEM_PACKAGE+: " foo-ng-1.0-bad"
  EXPECTED_PACKAGE: foo-1.4

/basic:
  summary+: " (only foo requested)"
  description: |
    System repo: foo-1.4 (baseline), foo-ng-1.0-bad
    Pre-installed: None
    Artifacts: None

    Broken `foo-ng` should be skipped and fallback to previous
    version on the system.

/pre-installed:
  summary+: " (foo pre-installed)"
  description: |
    System repo: foo-1.4 (baseline), foo-ng-1.0-bad
    Pre-installed: foo-1.4
    Artifacts: None

    Broken `foo-ng` should be skipped and no installation is done.

  environment+:
    PRE_INSTALLED_PACKAGE: rpms/foo-1.4/foo-1.4*.rpm

  /only-foo:
    summary+: " (only foo requested)"

  /with-devel:
    summary+: " (requested devel)"
    context+:
      want_devel: "true"
    environment+:
      EXPECTED_PACKAGE+: " foo-devel-1.4"
