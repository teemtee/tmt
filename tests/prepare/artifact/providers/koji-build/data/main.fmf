/plan:
    discover:
        how: fmf
    provision:
        how: container
    prepare:
      - how: artifact
        provide:
          # DUMMY_KOJI_BUILD_ID placeholder - replace with actual koji build ID
          # Example: koji.build:2761810
          - koji.build:DUMMY_KOJI_BUILD_ID
    execute:
        how: tmt

/plan/auto-verify:
    summary: Verify auto-inject of verify-installation phase when auto_verify=true (default)

/plan/no-verify:
    summary: Verify auto_verify=false suppresses auto-inject of verify-installation phase
    prepare:
      - how: artifact
        provide:
          - koji.build:DUMMY_KOJI_BUILD_ID
        auto_verify: false

/test:
    test: ./test.sh
    duration: 5m
    summary: Verify package from koji build
    require:
      - make
