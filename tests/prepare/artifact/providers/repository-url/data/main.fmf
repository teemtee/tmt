/plan:
    discover:
        how: fmf
    provision:
        how: container
    prepare:
        how: artifact
        provide:
          - repository-url:https://download.docker.com/linux/fedora/docker-ce.repo
    execute:
        how: tmt

/test:
    test: ./test.sh
    duration: 5m
    summary: Install and verify docker-ce-cli from external repository
