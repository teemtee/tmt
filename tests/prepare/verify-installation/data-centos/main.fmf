/plan:
    provision:
        how: container
    execute:
        how: tmt
    discover:
        how: fmf
        test: /test

/plan/success:
    prepare+:
      - how: verify-installation
        verify:
            make: baseos
            diffutils: "<unknown>"

/plan/failure:
    prepare+:
      - how: verify-installation
        verify:
            make: SOME_NON_EXISTENT_REPO
            diffutils: "<unknown>"
            random-non-existent-package: some-repo

/test:
    test: /bin/true
    require:
      - make
