/plan:
    provision:
        how: container
    execute:
        how: tmt
    discover:
        how: fmf
        test: /test

/plan/success:
    prepare+:
      - how: verify-installation
        verify:
            diffutils: fedora
            patch: fedora

/plan/failure:
    prepare+:
      - how: verify-installation
        verify:
            diffutils: fedora
            make: SOME_NON_EXISTENT_REPO
            random-non-existent-package: some-repo

/test:
    test: /bin/true
    require:
      - diffutils
      - make
      - patch
