/plan:
    provision:
        how: container
    execute:
        how: tmt
    discover:
        how: fmf
        test: /test
    prepare:
      - how: artifact
        provide:
          - koji.build:KOJI_BUILD_ID

/plan/success:
    prepare+:
      - how: verify-installation
        verify:
            centpkg: tmt-artifact-shared
            make: fedora
            diffutils: fedora

/plan/failure:
    prepare+:
      - how: verify-installation
        verify:
            centpkg: SOME_NON_EXISTENT_REPO
            make: fedora
            diffutils: fedora
            random-non-existent-package: some-repo

/test:
    test: /bin/true
    require:
      - centpkg
      - make
      - diffutils
