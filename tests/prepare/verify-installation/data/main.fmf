/plan:
    provision:
        how: container
    execute:
        how: tmt
    discover:
        how: fmf
        test: /test

/plan/success:
    prepare+:
      - how: verify-installation
        order: 79
        verify:
            bar: tmt-artifact-shared

/plan/failure:
    prepare+:
      - how: verify-installation
        order: 79
        verify:
            bar: SOME_NON_EXISTENT_REPO
            random-non-existent-package: some-repo

/test:
    test: /bin/true
    require:
      - bar
