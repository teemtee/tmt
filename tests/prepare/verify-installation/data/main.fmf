/plan/success:
    discover:
        how: fmf
        test: /test/success
    provision:
        how: container
    prepare:
      - how: artifact
        provide:
          - koji.build:KOJI_BUILD_ID
      - how: verify-installation
        verify:
          - package: make
            expected-repo: tmt-artifact-shared
          - package: make-devel
            expected-repo: tmt-artifact-shared
          - package: diffutils
            expected-repo: fedora
    execute:
        how: tmt

/test/success:
    test: /bin/true
    duration: 5m
    summary: Verify successful package source verification
    require:
      - make
      - make-devel
      - diffutils

/plan/failure:
    discover:
        how: fmf
        test: /test/failure
    provision:
        how: container
    prepare:
      - how: artifact
        provide:
          - koji.build:KOJI_BUILD_ID
      - how: verify-installation
        verify:
          - package: make
            expected-repo: tmt-artifact-shared
          - package: make-devel
            expected-repo: SOME_NON_EXISTENT_REPO
          - package: diffutils
            expected-repo: fedora
    execute:
        how: tmt

/test/failure:
    test: /bin/false
    duration: 5m
    summary: Verify package source verification fails with wrong repo
    require:
      - make
      - make-devel
      - diffutils
