/plan:
    discover:
        how: fmf
    provision:
        how: container
        image: centos:stream10
    prepare:
        how: feature
        epel: enabled
    execute:
        how: tmt

/test:
    framework: beakerlib
    test: |
        . /usr/share/beakerlib/beakerlib.sh
        rlJournalStart
        rlJournalEnd
