provision:
    how: $PROVISION_HOW

execute:
    how: tmt

/epel:
    discover:
        how: shell
        tests:
          - name: test
            test: ./check-repos.sh

    prepare:
      - how: feature

    environment:
        REPOSITORIES: epel

    /enabled:
        prepare+:
            epel: enabled

        environment+:
            STATE: enabled

        /default:

        /with-epel-preinstalled:
            prepare+<:
              - how: feature
                epel: enabled

    /disabled:
        prepare+:
            epel: disabled

        environment+:
            STATE: disabled

/gdbm:
    summary: Install gdbm available only in crb
    description: Check that crb repo is enabled
    prepare:
      - how: feature
        epel: enabled
      - how: install
        package: gdbm
    execute:
        script: gdbmtool --help

/profile:
    discover:
      how: shell
      tests:
        - name: test
          test: /bin/true

    prepare:
        how: feature
        profile: testing_farm_profiles.testing_farm
