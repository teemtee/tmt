summary: Install one package first, then check-first install of both - only the missing one should be installed
prepare: []

adjust:
  - when: distro == ubuntu,debian
    prepare+<:
      - how: shell
        script: apt-get update

  - when: distro != rhel
    prepare+:
      - how: install
        check-first: false
        package:
          - tree
      - how: install
        check-first: true
        package:
          - tree
          - dos2unix

  - when: distro == rhel
    prepare+:
      - how: install
        check-first: false
        package:
          - dconf
      - how: install
        check-first: true
        package:
          - dconf
          - libpng
