adjust:
    # On image mode, verify installed packages persist after reboot.
  - when: package_manager == bootc
    execute:
        how: tmt
        script: |
            tree --version && diffutils --version
            if [ "$TMT_REBOOT_COUNT" == "0" ]; then
                tmt-reboot
            fi

/in-cwd:
  summary: Install downloaded packages
  prepare:
    - how: install
      package:
        - tree.rpm
        - diffutils.rpm

/in-subdirectory:
  summary: Install downloaded packages from a subdirectory
  prepare:
    - how: install
      package:
        - downloaded-rpms/tree.rpm
        - downloaded-rpms/diffutils.rpm

/as-directory:
  summary: Install downloaded packages from a subdirectory
  prepare:
    - how: install
      directory: downloaded-rpms
