summary: Install existing packages
prepare: []

adjust:
  - when: distro == ubuntu,debian
    prepare+<:
      - how: shell
        script: apt-get update

    # Applies to every distro...
  - when: distro != rhel
    prepare+:
      - how: install
        package:
          - tree
          - diffutils

    # ... except UBI8 and UBI9 which do not ship tree and diffutils
  - when: distro == rhel
    prepare+:
      - how: install
        package:
          - dconf
          - libpng
