summary: TC 01 - Fresh install from artifact repo when system repo also has the package

/plan:
    discover:
        how: fmf
        test: /tc01/tc01/test
    provision:
        how: container
    execute:
        how: tmt
    prepare:
        - name: Copy repo directories to container
          how: shell
          script: |
              mkdir -p /tmp/artifact-test
              cp -r system tc01 /tmp/artifact-test/
        - name: Install repo files
          how: shell
          script: |
              cp repos/system.repo /etc/yum.repos.d/poc-system.repo
              cp repos/tc01.repo  /etc/yum.repos.d/poc-artifact-test.repo
              dnf clean all

/test:
    description: |
        foo is not pre-installed.  The system repo (priority=99) provides
        foo-1.4-1 and the artifact repo (priority=50) provides foo-1.1-1.

        Expected: dnf install foo-1.1-1.noarch installs foo-1.1 from the
        artifact repo because the lower numeric priority value (50) wins over
        the system repo's priority (99).
    test: |
        set -ex
        command -v dnf5 &>/dev/null && DNF=dnf5 || DNF=dnf

        $DNF install -y --repo='poc-*' foo-1.1-1.noarch
        rpm -q foo | grep -E '^foo-1\.1-1'
        $DNF repoquery --installed foo --qf '%{from_repo}' | grep -Fx 'poc-artifact-test'
