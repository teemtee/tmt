summary: "TC 02 - Upgrade: older version installed with unknown origin, artifact has newer"

/plan:
    discover:
        how: fmf
        test: /tc02/tc02/test
    provision:
        how: container
    execute:
        how: tmt
    prepare:
        - name: Copy repo directories to container
          how: shell
          script: |
              mkdir -p /tmp/artifact-test
              cp -r system preinstall tc02 /tmp/artifact-test/
        - name: Install repo files
          how: shell
          script: |
              cp repos/system.repo /etc/yum.repos.d/poc-system.repo
              cp repos/tc02.repo  /etc/yum.repos.d/poc-artifact-test.repo
              dnf clean all

/test:
    description: |
        foo-1.1-1 is pre-installed with unknown origin (rpm -i --force).
        The system repo (priority=99) provides foo-1.4-1 and the artifact repo
        (priority=50) provides foo-2.2-1.

        Expected: dnf install foo-2.2-1.noarch upgrades foo from 1.1 to 2.2,
        and the origin is recorded as poc-artifact-test.
    test: |
        set -ex
        command -v dnf5 &>/dev/null && DNF=dnf5 || DNF=dnf

        rpm -i --force /tmp/artifact-test/preinstall/foo-1.1-1.noarch.rpm
        rpm -q foo | grep -E '^foo-1\.1-1'

        $DNF install -y --repo='poc-*' foo-2.2-1.noarch
        rpm -q foo | grep -E '^foo-2\.2-1'
        $DNF repoquery --installed foo --qf '%{from_repo}' | grep -Fx 'poc-artifact-test'
