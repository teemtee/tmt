summary: "TC 03 - Downgrade: newer version installed with unknown origin, explicit NVRA"

/plan:
    discover:
        how: fmf
        test: /tc03/tc03/test
    provision:
        how: container
    execute:
        how: tmt
    prepare:
        - name: Copy repo directories to container
          how: shell
          script: |
              mkdir -p /tmp/artifact-test
              cp -r system preinstall tc03 /tmp/artifact-test/
        - name: Install repo files
          how: shell
          script: |
              cp repos/system.repo /etc/yum.repos.d/poc-system.repo
              cp repos/tc03.repo  /etc/yum.repos.d/poc-artifact-test.repo
              dnf clean all

/test:
    description: |
        foo-2.4-1 is pre-installed with unknown origin (rpm -i --force).
        The system repo (priority=99) provides foo-1.4-1 and the artifact repo
        (priority=50) provides foo-1.1-1.

        Expected: dnf install foo-1.1-1.noarch downgrades foo from 2.4 to 1.1,
        and the origin is recorded as poc-artifact-test.
        On DNF5, --allow-downgrade is required; DNF4 handles downgrade
        with an explicit NVRA without a special flag.
    test: |
        set -ex
        command -v dnf5 &>/dev/null && DNF=dnf5 || DNF=dnf

        rpm -i --force /tmp/artifact-test/preinstall/foo-2.4-1.noarch.rpm
        rpm -q foo | grep -E '^foo-2\.4-1'

        if [ "$DNF" = "dnf5" ]; then
            $DNF install -y --allow-downgrade --repo='poc-*' foo-1.1-1.noarch
        else
            $DNF install -y --repo='poc-*' foo-1.1-1.noarch
        fi
        rpm -q foo | grep -E '^foo-1\.1-1'
        $DNF repoquery --installed foo --qf '%{from_repo}' | grep -Fx 'poc-artifact-test'
